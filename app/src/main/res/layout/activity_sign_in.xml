<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#027335"
    tools:context=".sign_in">

    <!-- Top Green Background with Logo -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:background="#027335"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/logoImage"
            android:layout_width="120dp"
            android:layout_height="70dp"
            android:src="@drawable/signin_logo"
            android:contentDescription="Logo"
            android:scaleType="fitCenter"/>

        <TextView
            android:id="@+id/appTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="E-Commerce App"
            android:textSize="14sp"
            android:textColor="@android:color/white"/>
    </LinearLayout>

    <!-- White Card Area -->
    <LinearLayout
        android:id="@+id/cardLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="@drawable/bg_white_rounded"
        android:padding="24dp"
        android:elevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Title -->
        <TextView
            android:id="@+id/welcomeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome back"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#282F40"
            android:layout_marginBottom="6dp"/>

        <!-- Subtitle -->
        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor"
            android:textSize="14sp"
            android:textColor="#7D8FAB"
            android:layout_marginBottom="20dp"/>

        <!-- Username -->
        <EditText
            android:id="@+id/Edtemail"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_edittext"
            android:drawableStart="@drawable/ic_user"
            android:drawablePadding="12dp"
            android:hint="Username/Email"
            android:paddingStart="12dp"
            android:textColor="#282F40"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Password -->
        <EditText
            android:id="@+id/Edtpassword"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Password"
            android:inputType="textPassword"
            android:drawableStart="@drawable/ic_lock"
            android:drawablePadding="12dp"
            android:background="@drawable/bg_edittext_stroke"
            android:paddingStart="12dp"
            android:textColor="#282F40"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="20dp"/>

        <!-- Sign In Button -->
        <Button
            android:id="@+id/signInButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="SIGN IN"
            android:textAllCaps="true"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/green"
            android:layout_marginBottom="16dp"/>

        <!-- Remember Me + Forgot Password -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="30dp">

<!--            <CheckBox-->
<!--                android:id="@+id/rememberCheck"-->
<!--                android:layout_width="wrap_content"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:text="Keep Sign In"-->
<!--                android:textColor="#282F40"-->
<!--                android:buttonTint="#027335"/>-->

            <TextView
                android:layout_marginStart="230dp"
                android:id="@+id/forgotPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Forgot Password?"
                android:textColor="#027335"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Create Account -->
        <TextView
            android:id="@+id/createAccount"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="CREATE AN ACCOUNT"
            android:textColor="#027335"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/bg_button_white_border"/>

        />
    </LinearLayout>

    <!-- Progress overlay -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/progressOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:background="#80000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="64dp"
            android:layout_height="64dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>



</androidx.constraintlayout.widget.ConstraintLayout>