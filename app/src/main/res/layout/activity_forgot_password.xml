<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#027335"
    tools:context=".ForgotPassword">

    <!-- Top Green Background with Logo (same as sign_in) -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:background="#027335"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/logoImage"
            android:layout_width="120dp"
            android:layout_height="70dp"
            android:src="@drawable/signin_logo"
            android:contentDescription="Logo"
            android:scaleType="fitCenter"/>

        <TextView
            android:id="@+id/appTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="E-Commerce App"
            android:textSize="14sp"
            android:textColor="@android:color/white"/>
    </LinearLayout>

    <!-- White Card -->
    <LinearLayout
        android:id="@+id/cardLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="@drawable/bg_white_rounded"
        android:padding="24dp"
        android:elevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Title -->
        <TextView
            android:id="@+id/titleForgot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Forgot password"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#282F40"
            android:layout_marginBottom="6dp"/>

        <!-- Subtitle -->
        <TextView
            android:id="@+id/subtitleForgot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enter your registered email. We will send you a 6-digit OTP to reset your password."
            android:textSize="14sp"
            android:textColor="#7D8FAB"
            android:layout_marginBottom="20dp"/>

        <!-- STEP 1: EMAIL -->
        <LinearLayout
            android:id="@+id/emailStepLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <EditText
                android:id="@+id/EdtForgotEmail"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_edittext"
                android:drawableStart="@drawable/email"
                android:drawablePadding="12dp"
                android:hint="Registered Email"
                android:paddingStart="12dp"
                android:textColor="#282F40"
                android:textSize="16sp"
                android:textStyle="bold"
                android:inputType="textEmailAddress" />

            <Button
                android:id="@+id/btnSendOtp"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="SEND OTP"
                android:textAllCaps="true"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/green"
                android:layout_marginBottom="10dp"/>
        </LinearLayout>

        <!-- STEP 2: OTP + NEW PASSWORD (hidden first) -->
        <LinearLayout
            android:id="@+id/otpStepLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="We have sent an OTP to your email. Enter it below with your new password."
                android:textSize="14sp"
                android:textColor="#7D8FAB"
                android:layout_marginBottom="16dp"/>

            <!-- OTP -->
            <EditText
                android:id="@+id/EdtOtp"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_edittext"
                android:drawableStart="@drawable/ic_key"
                android:drawablePadding="12dp"
                android:hint="6-digit OTP"
                android:paddingStart="12dp"
                android:textColor="#282F40"
                android:textSize="16sp"
                android:textStyle="bold"
                android:inputType="number" />

            <!-- New password -->
            <EditText
                android:id="@+id/EdtNewPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="14dp"
                android:hint="New Password"
                android:inputType="textPassword"
                android:drawableStart="@drawable/ic_lock"
                android:drawablePadding="12dp"
                android:background="@drawable/bg_edittext_stroke"
                android:paddingStart="12dp"
                android:textColor="#282F40"
                android:textStyle="bold"
                android:textSize="16sp"/>

            <!-- Confirm password -->
            <EditText
                android:id="@+id/EdtConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="20dp"
                android:hint="Confirm Password"
                android:inputType="textPassword"
                android:drawableStart="@drawable/ic_lock"
                android:drawablePadding="12dp"
                android:background="@drawable/bg_edittext_stroke"
                android:paddingStart="12dp"
                android:textColor="#282F40"
                android:textStyle="bold"
                android:textSize="16sp"/>

            <Button
                android:id="@+id/btnResetPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="RESET PASSWORD"
                android:textAllCaps="true"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/green"
                android:layout_marginBottom="10dp"/>
        </LinearLayout>

        <!-- Back to Sign in -->
        <TextView
            android:id="@+id/tvBackToLogin"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="BACK TO SIGN IN"
            android:textColor="#027335"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/bg_button_white_border"
            android:layout_marginTop="10dp"/>

    </LinearLayout>

    <!-- Progress overlay (same style as sign_in) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/progressOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:background="#80000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="64dp"
            android:layout_height="64dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
