<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".MainActivity">

    <View
        android:id="@+id/topBackground"
        android:layout_width="0dp"
        android:layout_height="180dp"
        android:background="@android:color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_arrow_back"
        app:tint="@android:color/black"
        android:padding="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/profileImageContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/imgProfile"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_user"
            app:civ_border_color="@android:color/white"
            app:civ_border_width="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <ImageView
            android:id="@+id/btnEditImage"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_edit"
            android:padding="6dp"
            android:background="@drawable/bg_circle_edit"
            app:tint="@android:color/white"
            app:layout_constraintEnd_toEndOf="@id/imgProfile"
            app:layout_constraintBottom_toBottomOf="@id/imgProfile"
            android:elevation="2dp"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/profileImageContainer"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="24dp">

            <!-- Full Name -->
            <TextView
                style="@style/ProfileLabel"
                android:text="Full Name" />

            <EditText
                android:id="@+id/etFullName"
                style="@style/ProfileInput"
                android:hint="Louis Anderson"
                android:inputType="textPersonName" />

            <!-- Email -->
            <TextView
                style="@style/ProfileLabel"
                android:text="Email Address" />

            <EditText
                android:id="@+id/etEmail"
                style="@style/ProfileInput"
                android:hint="louisanderson@mail.com"
                android:inputType="textEmailAddress" />

            <!-- Phone -->
            <TextView
                style="@style/ProfileLabel"
                android:text="Phone" />

            <EditText
                android:id="@+id/etPhone"
                style="@style/ProfileInput"
                android:hint="Enter your phone number"
                android:background="@drawable/bg_search"
                android:inputType="phone" />

            <!-- Address -->
            <TextView
                style="@style/ProfileLabel"
                android:text="Address" />

            <EditText
                android:id="@+id/etAddress"
                style="@style/ProfileInput"
                android:hint="Type your home address"
                android:minLines="3"
                android:gravity="top|start"
                android:inputType="textPostalAddress" />

            <!-- Zip + City row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        style="@style/ProfileLabel"
                        android:text="Zip Code"
                        android:layout_marginTop="0dp"/>

                    <EditText
                        android:id="@+id/etZipCode"
                        style="@style/ProfileInput"
                        android:hint="Enter here"
                        android:layout_marginTop="4dp"
                        android:inputType="number" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        style="@style/ProfileLabel"
                        android:text="City"
                        android:layout_marginTop="0dp"/>

                    <EditText
                        android:id="@+id/etCity"
                        style="@style/ProfileInput"
                        android:hint="Enter here"
                        android:layout_marginTop="4dp"
                        android:inputType="text" />
                </LinearLayout>
            </LinearLayout>

            <!-- Buttons -->
            <Button
                android:id="@+id/btnEditProfile"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:backgroundTint="#1B5E20"
                android:text="Edit Profile"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnMyorders"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:backgroundTint="#1B5E20"
                android:text="My Orders"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
            <Button
                android:id="@+id/btnMyposts"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:backgroundTint="#1B5E20"
                android:text="My Posts"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:backgroundTint="#1B5E20"
                android:text="Log Out"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
